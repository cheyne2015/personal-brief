# DeepSeek API Key（必填）
# 从 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=sk-your-api-key-here

# DeepSeek 模型（可选，默认 deepseek-chat）
DEEPSEEK_MODEL=deepseek-chat

# 外部请求超时时间，单位毫秒（可选，默认 15000）
REQUEST_TIMEOUT_MS=15000

# 日期、每日限额和新闻缓存使用的时区
APP_TIMEZONE=Asia/Shanghai

# 运行时状态目录（每日限流计数等），默认 .runtime
RUNTIME_DIR=.runtime

# 允许访问后端的前端 Origin，逗号分隔
ALLOWED_ORIGINS=http://0cy.top,https://0cy.top,http://brief.0cy.top,https://brief.0cy.top

# 每 IP 每日 AI 请求限制
TRANSLATE_DAILY_LIMIT=50
ANALYSIS_DAILY_LIMIT=20
GENERATE_DAILY_LIMIT=10

# RSS 代理允许访问的域名，逗号分隔
RSS_PROXY_ALLOWLIST=actually-relevant-api.onrender.com,news.google.com

# 心知天气 API 密钥（可选，用于天气看板实时气温）
# 格式：uid1:key1,uid2:key2,...  支持多组轮询
# 从 https://www.seniverse.com/dashboard 获取
SENIVERSE_KEYS=your-uid:your-key

# 服务端口（可选，默认 3000）
PORT=3000
